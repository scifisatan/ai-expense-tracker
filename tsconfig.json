{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["@cloudflare/workers-types", "vite/client"],
    "forceConsistentCasingInFileNames": true,
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@apps/*": ["./src/apps/*"],
      "@web/*": ["./src/apps/web/*"],
      "@bot/*": ["./src/apps/bot/*"],
      "@api/*": ["./src/apps/api/*"]
    },
    "outDir": "dist"
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
